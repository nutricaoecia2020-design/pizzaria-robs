<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gerenciar Produtos - Pizzaria Robs</title>
    <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
    <style>
        body { font-family: 'Segoe UI', Arial, sans-serif; background: #f8f9fa; margin: 0; padding: 20px; color: #333; }
        .admin-container { max-width: 800px; margin: auto; background: white; padding: 30px; border-radius: 12px; box-shadow: 0 5px 20px rgba(0,0,0,0.1); }
        h1 { color: #e31837; text-align: center; margin-bottom: 30px; border-bottom: 2px solid #e31837; padding-bottom: 10px; }
        
        .form-box { background: #fff5f5; padding: 20px; border-radius: 10px; border: 1px solid #ffcccc; margin-bottom: 30px; }
        .form-group { margin-bottom: 15px; }
        label { display: block; font-weight: bold; margin-bottom: 5px; }
        input { width: 100%; padding: 12px; border: 1px solid #ccc; border-radius: 8px; box-sizing: border-box; }
        
        .btn { padding: 12px 20px; border: none; border-radius: 8px; cursor: pointer; font-weight: bold; transition: 0.2s; }
        .btn-add { background: #28a745; color: white; width: 100%; font-size: 16px; }
        .btn-add:hover { background: #218838; }
        .btn-del { background: #dc3545; color: white; padding: 6px 12px; font-size: 12px; }
        .btn-del:hover { background: #c82333; }

        table { width: 100%; border-collapse: collapse; margin-top: 20px; }
        th, td { padding: 12px; text-align: left; border-bottom: 1px solid #ddd; }
        th { background: #eee; }
        .img-tab { width: 50px; height: 50px; object-fit: cover; border-radius: 6px; }
        .loading { text-align: center; color: #666; padding: 20px; }
    </style>
</head>
<body>

<div class="admin-container">
    <h1>⚙️ Painel de Produtos</h1>

    <div class="form-box">
        <h3>Cadastrar Novo Item</h3>
        <div class="form-group">
            <label>Nome do Produto</label>
            <input type="text" id="nome" placeholder="Ex: Pizza de Frango com Catupiry">
        </div>
        <div class="form-group">
            <label>Preço (R$)</label>
            <input type="number" step="0.01" id="preco" placeholder="0.00">
        </div>
        <div class="form-group">
            <label>Link da Imagem (URL)</label>
            <input type="text" id="imagem" placeholder="https://site.com/foto.jpg">
        </div>
        <button class="btn btn-add" onclick="salvar()">Adicionar ao Cardápio</button>
    </div>

    <h3>Produtos no Site</h3>
    <div id="lista-container">
        <p class="loading">Carregando produtos...</p>
    </div>
</div>

<script>
    // Configurações Supabase
    const supabaseUrl = 'https://gsvvyktjeqlmhspqzppy.supabase.co';
    const supabaseKey = 'sb_publishable_0lVSMGWIIYBvwu_iWWWPKw_qvoAHjOs';
    const _supabase = supabase.createClient(supabaseUrl, supabaseKey);

    // 1. CARREGAR PRODUTOS
    async function carregar() {
        const container = document.getElementById("lista-container");
        const { data: produtos, error } = await _supabase
            .from('produtos')
            .select('*')
            .order('nome', { ascending: true });

        if (error) {
            container.innerHTML = "<p style='color:red'>Erro ao carregar banco de dados.</p>";
            console.error(error);
            return;
        }

        if (produtos.length === 0) {
            container.innerHTML = "<p>Nenhum produto encontrado.</p>";
            return;
        }

        let html = `<table>
            <tr>
                <th>Foto</th>
                <th>Nome</th>
                <th>Preço</th>
                <th>Ações</th>
            </tr>`;

        produtos.forEach(p => {
            html += `
                <tr>
                    <td><img src="${p.url_imagem || 'https://via.placeholder.com/50'}" class="img-tab"></td>
                    <td>${p.nome}</td>
                    <td>R$ ${parseFloat(p.preco).toFixed(2)}</td>
                    <td>
                        <button class="btn btn-del" onclick="deletar(${p.id})">Excluir</button>
                    </td>
                </tr>
            `;
        });

        html += `</table>`;
        container.innerHTML = html;
    }

    // 2. SALVAR PRODUTO
    async function salvar() {
        const nome = document.getElementById("nome").value;
        const preco = document.getElementById("preco").value;
        const url_imagem = document.getElementById("imagem").value;

        if (!nome || !preco) {
            alert("Por favor, preencha nome e preço!");
            return;
        }

        const { error } = await _supabase
            .from('produtos')
            .insert([{ nome, preco: parseFloat(preco), url_imagem }]);

        if (error) {
            alert("Erro ao salvar: " + error.message);
        } else {
            alert("Produto cadastrado!");
            document.getElementById("nome").value = "";
            document.getElementById("preco").value = "";
            document.getElementById("imagem").value = "";
            carregar();
        }
    }

    // 3. DELETAR PRODUTO (A função que você precisava)
    window.deletar = async function(id) {
        if (confirm("Deseja realmente remover este item do cardápio?")) {
            console.log("Tentando deletar ID:", id);

            const { error } = await _supabase
                .from('produtos')
                .delete()
                .eq('id', id); // O nome da coluna no Supabase deve ser 'id'

            if (error) {
                console.error("Erro completo:", error);
                alert("Erro ao deletar: " + error.message + "\nVerifique se o RLS (política de delete) está ativo no Supabase.");
            } else {
                alert("Removido com sucesso!");
                carregar(); // Atualiza a lista na tela
            }
        }
    }

    // Iniciar ao carregar a página
    carregar();
</script>

</body>
</html>
